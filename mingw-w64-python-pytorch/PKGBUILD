_realname=pytorch
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=2.11.0
pkgrel=2
_srcdir=${_realname}-v${pkgver}
pkgdesc="Tensors and dynamic neural networks in Python (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64') # 'clang64' 'clangarm64')
url="https://pytorch.org/"
msys2_repository_url="https://github.com/pytorch/pytorch"
msys2_references=(
  "pypi: torch"
)
license=('spdx:BSD-3-Clause')
depends=("${MINGW_PACKAGE_PREFIX}-python"
         "${MINGW_PACKAGE_PREFIX}-python-filelock"
         "${MINGW_PACKAGE_PREFIX}-python-fsspec"
         "${MINGW_PACKAGE_PREFIX}-python-jinja"
         "${MINGW_PACKAGE_PREFIX}-python-networkx"
         "${MINGW_PACKAGE_PREFIX}-python-numpy"
         "${MINGW_PACKAGE_PREFIX}-python-optree"
         "${MINGW_PACKAGE_PREFIX}-python-sympy"
         "${MINGW_PACKAGE_PREFIX}-python-typing_extensions"
         "${MINGW_PACKAGE_PREFIX}-cc-libs"
         #"${MINGW_PACKAGE_PREFIX}-gflags"
         "${MINGW_PACKAGE_PREFIX}-glog"
         "${MINGW_PACKAGE_PREFIX}-omp"
         "${MINGW_PACKAGE_PREFIX}-openblas"
         "${MINGW_PACKAGE_PREFIX}-protobuf"
         "${MINGW_PACKAGE_PREFIX}-sleef"
         "${MINGW_PACKAGE_PREFIX}-vulkan-loader")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-benchmark"
             "${MINGW_PACKAGE_PREFIX}-eigen3"
             "${MINGW_PACKAGE_PREFIX}-fftw"
             "${MINGW_PACKAGE_PREFIX}-fmt"
             "${MINGW_PACKAGE_PREFIX}-flatbuffers"
             "${MINGW_PACKAGE_PREFIX}-nlohmann-json"
             "${MINGW_PACKAGE_PREFIX}-pybind11"
             "${MINGW_PACKAGE_PREFIX}-shaderc"
             "${MINGW_PACKAGE_PREFIX}-vulkan-headers"
             "${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-packaging"
             "${MINGW_PACKAGE_PREFIX}-python-protobuf"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
             "${MINGW_PACKAGE_PREFIX}-python-wheel"
             "${MINGW_PACKAGE_PREFIX}-python-yaml")
options=(!strip)
source=("https://github.com/pytorch/pytorch/releases/download/v${pkgver}/pytorch-v${pkgver}.tar.gz"
        "0001-pytorch-use-system-libraries.patch"
        "0002-pytorch-find-eigen3-config.patch"
        "0003-pytorch-mingw-port.patch"
        "0004-fix-build-with-glog-0.7.patch"
        "0005-define-uint-for-aarch64.patch")
sha256sums=('ab3fde9e7e382f45ac942be6ea2c2ef362c5ccd6f55ed6d5f35e6ea81d3ab88e'
            'ee509420cada0283dc0a5ad2a6c0128e9482e253f98666329d87526a1b4db150'
            '80ea46b21ddf7fc841222a2e4753206d192a025242e33c17163dfced27b8468c'
            '0e4f65f524fa7d637a520ed743731a186267a472011c9dd15370e0082196bc0a'
            'f4cdf71e5faab74ef8eb4d4fbcbe95b1b957e7065f58225136323cd87d64a5e1'
            'a09716dee7ed8a532c33208291bc4c71885a1b48f4ce075628ccd2993bf4d7b3')
noextract=("pytorch-v${pkgver}.tar.gz")

apply_patch_with_msg() {
  for _patch in "$@"; do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  echo "Extracting pytorch-v${pkgver}.tar.gz ..." 
  ${MINGW_PREFIX}/bin/bsdtar.exe -xzf pytorch-v${pkgver}.tar.gz || true

  cd "${srcdir}/${_srcdir}"

  apply_patch_with_msg \
    0001-pytorch-use-system-libraries.patch \
    0002-pytorch-find-eigen3-config.patch \
    0003-pytorch-mingw-port.patch \
    0004-fix-build-with-glog-0.7.patch \
    0005-define-uint-for-aarch64.patch
}

build() {
  cd "${srcdir}/${_srcdir}"

  export PYTORCH_BUILD_VERSION="${pkgver}"
  export PYTORCH_BUILD_NUMBER=1
  export PYTORCH_PACKAGE_USE_DECLARED_SUBMODULES=ON
  export BUILD_TEST=OFF
  export USE_CUDA=OFF
  export USE_ROCM=OFF
  export USE_DISTRIBUTED=OFF
  export USE_GFLAGS=OFF
  export USE_GLOG=ON
  export USE_GLOO=OFF
  export USE_TENSORPIPE=OFF
  export USE_MKLDNN=OFF
  export USE_NNPACK=OFF
  export USE_QNNPACK=OFF
  export USE_PYTORCH_QNNPACK=OFF
  export USE_XNNPACK=OFF
  export USE_FBGEMM=OFF
  export USE_KINETO=OFF
  export USE_OPENMP=ON
  export USE_NUMA=OFF
  export USE_MPS=OFF
  export USE_XPU=OFF
  export USE_ITT=OFF
  export USE_MIMALLOC=OFF
  export USE_VULKAN=ON
  export USE_SYSTEM_BENCHMARK=ON
  export USE_SYSTEM_EIGEN_INSTALL=ON
  export USE_SYSTEM_PYBIND11=ON
  export USE_SYSTEM_SLEEF=ON
  export BUILD_CUSTOM_PROTOBUF=OFF
  export CAFFE2_LINK_LOCAL_PROTOBUF=OFF
  export BLAS=OpenBLAS
  export OpenBLAS_HOME="${MINGW_PREFIX}"
  export OpenBLAS_LIB_NAME=openblas
  CFLAGS+=" -w"
  CXXFLAGS+=" -w"

  ${MINGW_PREFIX}/bin/python setup.py bdist_wheel
}

package() {
  cd "${srcdir}/${_srcdir}"

  local _install_dir=$(mktemp -d)
  local _install_dest=$(cygpath -m "${_install_dir}")

  MSYS2_ARG_CONV_EXCL="--prefix=;--destdir=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${_install_dest}" dist/*.whl

  mkdir -p "${pkgdir}"
  cp -a "${_install_dir}/." "${pkgdir}/"
  rm -rf "${_install_dir}"

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE"
}
