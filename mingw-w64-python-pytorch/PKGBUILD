# Contributor: Kreijstal <Kreijstal@users.noreply.github.com>

_realname=pytorch
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=2.11.0
pkgrel=1
_srcdir=${_realname}-v${pkgver}
pkgdesc="Tensors and dynamic neural networks in Python (mingw-w64)"
arch=('any')
mingw_arch=('ucrt64')
url="https://pytorch.org/"
msys2_repository_url="https://github.com/pytorch/pytorch"
msys2_references=(
  "pypi: torch"
)
license=('spdx:BSD-3-Clause')
depends=("${MINGW_PACKAGE_PREFIX}-python"
         "${MINGW_PACKAGE_PREFIX}-python-filelock"
         "${MINGW_PACKAGE_PREFIX}-python-fsspec"
         "${MINGW_PACKAGE_PREFIX}-python-jinja"
         "${MINGW_PACKAGE_PREFIX}-python-networkx"
         "${MINGW_PACKAGE_PREFIX}-python-numpy"
         "${MINGW_PACKAGE_PREFIX}-python-optree"
         "${MINGW_PACKAGE_PREFIX}-python-sympy"
         "${MINGW_PACKAGE_PREFIX}-python-typing_extensions"
         "${MINGW_PACKAGE_PREFIX}-eigen3"
         "${MINGW_PACKAGE_PREFIX}-gcc-libs"
         "${MINGW_PACKAGE_PREFIX}-fmt"
         "${MINGW_PACKAGE_PREFIX}-flatbuffers"
         "${MINGW_PACKAGE_PREFIX}-nlohmann-json"
         "${MINGW_PACKAGE_PREFIX}-openblas")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-benchmark"
             "${MINGW_PACKAGE_PREFIX}-cmake"
             "git"
             "${MINGW_PACKAGE_PREFIX}-ninja"
             "${MINGW_PACKAGE_PREFIX}-protobuf"
             "${MINGW_PACKAGE_PREFIX}-pybind11"
             "${MINGW_PACKAGE_PREFIX}-python-build"
             "${MINGW_PACKAGE_PREFIX}-python-installer"
             "${MINGW_PACKAGE_PREFIX}-python-packaging"
             "${MINGW_PACKAGE_PREFIX}-python-protobuf"
             "${MINGW_PACKAGE_PREFIX}-python-setuptools"
             "${MINGW_PACKAGE_PREFIX}-python-wheel"
             "${MINGW_PACKAGE_PREFIX}-python-yaml")
options=(!strip)
source=("https://github.com/pytorch/pytorch/releases/download/v${pkgver}/pytorch-v${pkgver}.tar.gz"
        "0001-pytorch-use-system-libraries.patch"
        "0002-pytorch-find-eigen3-config.patch"
        "0003-pytorch-mingw-port.patch"
        "0004-third_party-onnx-optional-macro.patch")
sha256sums=('ab3fde9e7e382f45ac942be6ea2c2ef362c5ccd6f55ed6d5f35e6ea81d3ab88e'
            'ee509420cada0283dc0a5ad2a6c0128e9482e253f98666329d87526a1b4db150'
            '80ea46b21ddf7fc841222a2e4753206d192a025242e33c17163dfced27b8468c'
            'a76d096a86161891cb658018890426dd33b39e71bfabd79d46c96768d886879a'
            'ab4972112b3f3791d113a884ece1ddd1f81a63ac6970df044d0867aa75df2eb4')
noextract=("pytorch-v${pkgver}.tar.gz")

apply_patch_with_msg() {
  for _patch in "$@"; do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

prepare() {
  local _symlink
  local _bsdtar_args=()

  for _symlink in \
    ".dockerignore" \
    "third_party/nccl/pkg/debian/copyright" \
    "third_party/flatbuffers/java/src/test/java/optional_scalars" \
    "third_party/flatbuffers/java/src/test/java/NamespaceA" \
    "third_party/flatbuffers/java/src/test/java/NamespaceC" \
    "third_party/flatbuffers/java/src/test/java/DictionaryLookup" \
    "third_party/flatbuffers/java/src/test/java/MyGame" \
    "third_party/flatbuffers/java/src/test/java/union_vector" \
    "third_party/flatbuffers/tests/ts/bazel_repository_test_dir/.npmrc" \
    "third_party/flatbuffers/docs/source/CONTRIBUTING.md" \
    "third_party/XNNPACK/tools/xngen" \
    "third_party/ittapi/rust/ittapi-sys/LICENSES" \
    "third_party/ittapi/rust/ittapi-sys/c-library" \
    "third_party/kineto/libkineto/third_party/dynolog/third_party/prometheus-cpp/cmake/project-import-cmake/sample_client.cc" \
    "third_party/kineto/libkineto/third_party/dynolog/third_party/prometheus-cpp/cmake/project-import-cmake/sample_server.cc" \
    "third_party/kineto/libkineto/third_party/dynolog/third_party/prometheus-cpp/cmake/project-import-pkgconfig/sample_client.cc" \
    "third_party/kineto/libkineto/third_party/dynolog/third_party/prometheus-cpp/cmake/project-import-pkgconfig/sample_server.cc"; do
    _bsdtar_args+=(--exclude "${_srcdir}/${_symlink}")
  done

  bsdtar -xf "${srcdir}/pytorch-v${pkgver}.tar.gz" -C "${srcdir}" \
    "${_bsdtar_args[@]}"

  cd "${srcdir}/${_srcdir}"

  apply_patch_with_msg \
    0001-pytorch-use-system-libraries.patch \
    0002-pytorch-find-eigen3-config.patch \
    0003-pytorch-mingw-port.patch

  patch -Nbp1 -d third_party/onnx -i "${srcdir}/0004-third_party-onnx-optional-macro.patch"
}

build() {
  cd "${srcdir}/${_srcdir}"

  export PYTORCH_BUILD_VERSION="${pkgver}"
  export PYTORCH_BUILD_NUMBER="${pkgrel}"
  export PYTORCH_PACKAGE_USE_DECLARED_SUBMODULES=1
  export BUILD_TEST=0
  export USE_CUDA=0
  export USE_ROCM=0
  export USE_DISTRIBUTED=0
  export USE_GLOO=0
  export USE_TENSORPIPE=0
  export USE_MKLDNN=0
  export USE_NNPACK=0
  export USE_QNNPACK=0
  export USE_PYTORCH_QNNPACK=0
  export USE_XNNPACK=0
  export USE_FBGEMM=0
  export USE_KINETO=0
  export USE_OPENMP=0
  export USE_NUMA=0
  export USE_MPS=0
  export USE_XPU=0
  export USE_ITT=0
  export USE_MIMALLOC=0
  export USE_SYSTEM_BENCHMARK=1
  export USE_SYSTEM_EIGEN_INSTALL=1
  export USE_SYSTEM_PYBIND11=1
  export BUILD_CUSTOM_PROTOBUF=0
  export CAFFE2_LINK_LOCAL_PROTOBUF=0
  export BLAS=OpenBLAS
  export OpenBLAS_HOME="${MINGW_PREFIX}"
  export OpenBLAS_LIB_NAME=openblas

  ${MINGW_PREFIX}/bin/python setup.py bdist_wheel
}

package() {
  cd "${srcdir}/${_srcdir}"

  local _install_dir=$(mktemp -d)
  local _install_dest=$(cygpath -m "${_install_dir}")

  MSYS2_ARG_CONV_EXCL="--prefix=;--destdir=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="${_install_dest}" dist/*.whl

  mkdir -p "${pkgdir}"
  cp -a "${_install_dir}/." "${pkgdir}/"
  rm -rf "${_install_dir}"

  install -Dm644 LICENSE "${pkgdir}${MINGW_PREFIX}/share/licenses/python-${_realname}/LICENSE"
}
