--- /dev/null
+++ b/ld/testsuite/ld-pe/weak-ext-main-weak.c
@@ -0,0 +1,22 @@
+/* Weak declaration of func (no definition).  */
+#include <stdio.h>
+
+__attribute__((weak)) void func (void);
+void dummy (void);
+
+int value = 1;
+extern int expected;
+
+int
+main (void)
+{
+  if (func)
+    func ();
+  dummy ();
+  if (value != expected)
+    {
+      printf ("expected %d, got %d\n", expected, value);
+      return 1;
+    }
+  return 0;
+}
