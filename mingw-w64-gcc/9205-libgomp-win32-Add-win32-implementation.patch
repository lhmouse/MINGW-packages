+   <http://www.gnu.org/licenses/>.  */
+
+/* This is the Windows Vista+ implementation of the public OpenMP locking
+   primitives.
+
+   Because OpenMP uses different entry points for normal and recursive
+   locks, and pthreads uses only one entry point, a system may be able
+   to do better and streamline the locking as well as reduce the size
+   of the types exported.  */
+
+#include "libgomp.h"
+
+void
+omp_init_lock (omp_lock_t *lock)
+{
+  InitializeSRWLock (&lock->mutex);
+  InitializeConditionVariable (&lock->cond);
+  lock->owner = NULL;
+}
+
+void
+omp_destroy_lock (omp_lock_t *lock)
+{
+  (void) lock;
+}
+
+void
+omp_set_lock (omp_lock_t *lock)
+{
+  void *me = gomp_icv (true);
+
+  /* Wait for owner to become null.  */
+  AcquireSRWLockExclusive (&lock->mutex);
+  while (lock->owner != NULL)
+    SleepConditionVariableSRW (&lock->cond, &lock->mutex, INFINITE, 0);
+
+  /* Take ownership.  */
+  __atomic_store_n (&lock->owner, me, MEMMODEL_RELAXED);
+  ReleaseSRWLockExclusive (&lock->mutex);
+}
+
+void
+omp_unset_lock (omp_lock_t *lock)
+{
+  /* Release ownership.  */
+  AcquireSRWLockExclusive (&lock->mutex);
+  __atomic_store_n (&lock->owner, NULL, MEMMODEL_RELAXED);
+  ReleaseSRWLockExclusive (&lock->mutex);
+  WakeConditionVariable (&lock->cond);
+}
+
+int
+omp_test_lock (omp_lock_t *lock)
+{
+  void *me = gomp_icv (true);
+
+  /* See if owner is null.  If it isn't, fail.  */
+  if (!TryAcquireSRWLockExclusive (&lock->mutex))
+    return 0;
+  if (lock->owner != NULL)
+    {
+      ReleaseSRWLockExclusive (&lock->mutex);
+      return 0;
+    }
+
+  /* Take ownership.  */
+  __atomic_store_n (&lock->owner, me, MEMMODEL_RELAXED);
+  ReleaseSRWLockExclusive (&lock->mutex);
+  return 1;
+}
+
+void
+omp_init_nest_lock (omp_nest_lock_t *lock)
+{
+  InitializeSRWLock (&lock->mutex);
+  InitializeConditionVariable (&lock->cond);
+  lock->count = 0;
+  lock->owner = NULL;
+}
+
+void
+omp_destroy_nest_lock (omp_nest_lock_t *lock)
+{
+  (void) lock;
+}
+
+void
+omp_set_nest_lock (omp_nest_lock_t *lock)
+{
+  void *me = gomp_icv (true);
+
+  if (__atomic_load_n (&lock->owner, MEMMODEL_RELAXED) != me)
+    {
+      /* Wait for owner to become null.  */
+      AcquireSRWLockExclusive (&lock->mutex);
+      while (lock->owner != NULL)
+	SleepConditionVariableSRW (&lock->cond, &lock->mutex, INFINITE, 0);
+
+      /* Take ownership.  */
+      __atomic_store_n (&lock->owner, me, MEMMODEL_RELAXED);
+      ReleaseSRWLockExclusive (&lock->mutex);
+    }
+
+  lock->count++;
+}
+
+void
+omp_unset_nest_lock (omp_nest_lock_t *lock)
+{
+  if (--lock->count == 0)
+    {
+      /* Release ownership.  */
+      AcquireSRWLockExclusive (&lock->mutex);
+      __atomic_store_n (&lock->owner, NULL, MEMMODEL_RELAXED);
+      ReleaseSRWLockExclusive (&lock->mutex);
+      WakeConditionVariable (&lock->cond);
+    }
+}
+
+int
+omp_test_nest_lock (omp_nest_lock_t *lock)
+{
+  void *me = gomp_icv (true);
+
+  if (__atomic_load_n (&lock->owner, MEMMODEL_RELAXED) != me)
+    {
+      /* See if owner is null.  If it isn't, fail.  */
+      if (!TryAcquireSRWLockExclusive (&lock->mutex))
+	return 0;
+      if (lock->owner != NULL)
+	{
+	  ReleaseSRWLockExclusive (&lock->mutex);
+	  return 0;
+	}
+
+      /* Take ownership.  */
+      __atomic_store_n (&lock->owner, me, MEMMODEL_RELAXED);
+      ReleaseSRWLockExclusive (&lock->mutex);
+    }
+
+  return ++lock->count;
+}
+
+ialias (omp_init_lock)
+ialias (omp_init_nest_lock)
+ialias (omp_destroy_lock)
+ialias (omp_destroy_nest_lock)
+ialias (omp_set_lock)
+ialias (omp_set_nest_lock)
+ialias (omp_unset_lock)
+ialias (omp_unset_nest_lock)
+ialias (omp_test_lock)
+ialias (omp_test_nest_lock)
