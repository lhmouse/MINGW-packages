+/* This is the Windows Vista+ implementation of a mutex synchronization
+   mechanism for libgomp.  This type is private to the library.  */
+
+#ifndef GOMP_MUTEX_H
+#define GOMP_MUTEX_H 1
+
+#define WIN32_LEAN_AND_MEAN
+#include <windows.h>
+
+typedef SRWLOCK gomp_mutex_t;
+
+#define GOMP_MUTEX_INIT_0 1
+
+static inline void gomp_mutex_init (gomp_mutex_t *mutex)
+{
+  InitializeSRWLock (mutex);
+}
+
+static inline void gomp_mutex_lock (gomp_mutex_t *mutex)
+{
+  AcquireSRWLockExclusive (mutex);
+}
+
+static inline void gomp_mutex_unlock (gomp_mutex_t *mutex)
+{
+  ReleaseSRWLockExclusive (mutex);
+}
+
+static inline void gomp_mutex_destroy (gomp_mutex_t *mutex)
+{
+  (void) mutex;
+}
+
+#endif /* GOMP_MUTEX_H */
diff --git a/libgomp/config/win32/omp-lock.h b/libgomp/config/win32/omp-lock.h
new file mode 100644
index 000000000000..a7218db23834
--- /dev/null
+++ b/libgomp/config/win32/omp-lock.h
@@ -0,0 +1,26 @@
+/* This header is used during the build process to find the size and
+   alignment of the public OpenMP locks, so that we can export data
+   structures without polluting the namespace.
+
+   Windows doesn't support symbol versioning, so OpenMP 2.5 locks are not
+   implemented. For OpenMP 3.0, a lock may be unlocked by a different thread
+   from the one that locked it, so a condition variable is necessary.  */
+
+#define WIN32_LEAN_AND_MEAN
+#include <windows.h>
+
+typedef struct {
+  SRWLOCK mutex;
+  CONDITION_VARIABLE cond;
+  void *owner;
+} omp_lock_t;
+
+typedef struct {
+  SRWLOCK mutex;
+  CONDITION_VARIABLE cond;
+  int count;
+  void *owner;
+} omp_nest_lock_t;
+
+typedef omp_lock_t omp_lock_25_t;
+typedef omp_nest_lock_t omp_nest_lock_25_t;
