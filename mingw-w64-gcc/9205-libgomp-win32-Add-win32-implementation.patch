+   see the files COPYING3 and COPYING.RUNTIME respectively.  If not, see
+   <http://www.gnu.org/licenses/>.  */
+
+/* This is the Windows Vista+ implementation of a semaphore synchronization
+   mechanism for libgomp.  This type is private to the library.  */
+
+#include "libgomp.h"
+
+void gomp_sem_init (gomp_sem_t *sem, int value)
+{
+  InitializeSRWLock (&sem->mutex);
+  InitializeConditionVariable (&sem->cond);
+  sem->value = value;
+}
+
+void gomp_sem_wait (gomp_sem_t *sem)
+{
+  AcquireSRWLockExclusive (&sem->mutex);
+  while (sem->value <= 0)
+    SleepConditionVariableSRW (&sem->cond, &sem->mutex, INFINITE, 0);
+  sem->value--;
+  ReleaseSRWLockExclusive (&sem->mutex);
+}
+
+void gomp_sem_post (gomp_sem_t *sem)
+{
+  AcquireSRWLockExclusive (&sem->mutex);
+  sem->value++;
+  ReleaseSRWLockExclusive (&sem->mutex);
+  WakeConditionVariable (&sem->cond);
+}
+
+int gomp_sem_getcount (gomp_sem_t *sem)
+{
+  AcquireSRWLockExclusive (&sem->mutex);
+  int count = sem->value;
+  ReleaseSRWLockExclusive (&sem->mutex);
+  return count;
+}
